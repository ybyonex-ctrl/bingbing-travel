# Runtime
NODE_ENV=production
PORT=3001
SERVE_STATIC=false
# Leave unset to use <project>/netlify-deploy.
STATIC_DIR=
DATA_DIR=/var/lib/bingbing-travel
# DB_PATH=/var/lib/bingbing-travel/bbuser.db
TRUST_PROXY_HOPS=1

# Required in production: unique random value, at least 48 characters.
JWT_SECRET=replace-with-at-least-48-random-characters
# Optional. Leave empty to disable the admin cleanup endpoint.
ADMIN_TOKEN=
# Optional exact client IPs, comma separated. Enforced only when non-empty.
ADMIN_IP_ALLOWLIST=
# Optional salt for irreversible IP fingerprints in security logs.
SECURITY_LOG_SALT=

# Browser origins allowed to call the API in production. No wildcard.
ALLOWED_ORIGINS=https://your-site.netlify.app,https://travel.example.com
# Development-only escape hatch for file:// pages; keep false in production.
ALLOW_FILE_ORIGIN=false

# Request and rate limits
REQUEST_BODY_LIMIT=256kb
GLOBAL_RATE_LIMIT_MAX=240
AUTH_RATE_LIMIT_MAX=15
PASSWORD_RESET_RATE_LIMIT_MAX=6
ADMIN_RATE_LIMIT_MAX=5

# DeepSeek BYOK proxy controls
# Never set or commit a shared DEEPSEEK_API_KEY. Every user supplies their own
# key per request; the server does not persist or log it.
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODELS_TIMEOUT_MS=20000
DEEPSEEK_CHAT_TIMEOUT_MS=180000
UPSTREAM_RESPONSE_LIMIT_BYTES=2097152
AI_IP_RATE_LIMIT_MAX=24
AI_USER_RATE_LIMIT_MAX=16
AI_DAILY_QUOTA=60
AI_USER_CONCURRENCY=1
AI_GLOBAL_CONCURRENCY=8
AI_MAX_TOKENS=4096

# Optional country filtering for /api/auth/*, /api/ai/* and /api/admin/*.
# Country headers are useful only behind a trusted CDN/proxy such as Cloudflare.
GEO_BLOCK_ENABLED=false
# If ALLOWED_COUNTRIES is non-empty, other reported countries are denied.
ALLOWED_COUNTRIES=CN,HK,MO
BLOCKED_COUNTRIES=
# Keep false unless the admin route is always behind a proxy that supplies a country header.
GEO_REQUIRE_COUNTRY_HEADER_FOR_ADMIN=false

# Password reset email (optional in development; required for production reset flow)
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=replace-with-sender@qq.com
SMTP_PASS=replace-with-smtp-app-password
SMTP_FROM=冰冰出行 <replace-with-sender@qq.com>
SMTP_EHLO_HOST=travel.example.com
SMTP_REJECT_UNAUTHORIZED=true
